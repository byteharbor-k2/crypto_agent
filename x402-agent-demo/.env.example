# Environment Configuration for x402 Agent Demo

# ==== Anthropic API Configuration ====
# Supported values: anthropic, openai, ollama, omlx, mlx
LLM_PROVIDER=anthropic

# Get your API key from: https://console.anthropic.com/
# Native Anthropic:
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional Claude-compatible gateway, e.g. B.AI:
ANTHROPIC_BASE_URL=https://api.b.ai
ANTHROPIC_AUTH_TOKEN=your_anthropic_or_bai_api_key_here

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=http://127.0.0.1:8000/v1
OPENAI_MODEL=your_local_model_id
OPENAI_REQUEST_TIMEOUT=120
OPENAI_MAX_TOKENS=1024

# ==== Agent Wallet Configuration ====
# For demo purposes, you can generate a test wallet
# In production, use a real wallet with actual funds
AGENT_PRIVATE_KEY=your_private_key_here
AGENT_WALLET_ADDRESS=your_wallet_address_here

# ==== Payment Policy ====
# Maximum amount (in USDC) that can be auto-approved without user confirmation
MAX_AUTO_APPROVE_AMOUNT=1.0

# ==== Web3 Configuration ====
# RPC URL for blockchain connection (using Sepolia testnet for demo)
WEB3_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/demo

# ==== Mock Service Configuration ====
# Port for the mock x402 service
MOCK_SERVICE_PORT=5000

# ==== Optional: Session Budget ====
# Maximum total spending per session (not implemented yet)
SESSION_BUDGET=10.0

# ==== Real x402 Discovery / Dry Run ====
# Coinbase x402 Bazaar discovery endpoint
X402_BAZAAR_BASE_URL=https://api.cdp.coinbase.com/platform/v2/x402/discovery

# Keep false until a real payment adapter is implemented and explicitly tested.
ALLOW_REAL_X402_PAYMENT=false

# Timeout for probing real x402 URLs
X402_REQUEST_TIMEOUT=15
