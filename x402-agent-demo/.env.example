# Environment Configuration for x402 Agent Demo

# ==== Anthropic API Configuration ====
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

OPENAI_API_KEY=your_openai_api_key_here

# ==== Agent Wallet Configuration ====
# For demo purposes, you can generate a test wallet
# In production, use a real wallet with actual funds
AGENT_PRIVATE_KEY=your_private_key_here
AGENT_WALLET_ADDRESS=your_wallet_address_here

# ==== Payment Policy ====
# Maximum amount (in USDC) that can be auto-approved without user confirmation
MAX_AUTO_APPROVE_AMOUNT=1.0

# ==== Web3 Configuration ====
# RPC URL for blockchain connection (using Sepolia testnet for demo)
WEB3_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/demo

# ==== Mock Service Configuration ====
# Port for the mock x402 service
MOCK_SERVICE_PORT=5000

# ==== Optional: Session Budget ====
# Maximum total spending per session (not implemented yet)
SESSION_BUDGET=10.0
